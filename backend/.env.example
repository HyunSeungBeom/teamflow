# ──────────────────────────────────────────────────────────────────────
# teamflow-api 환경 변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   # 이후 본인 값으로 채움
#
# 참고:
#   - docker compose up 으로 실행하면 DB/Redis 연결 값은 compose 파일이
#     컨테이너 네트워크용 값으로 덮어씁니다 (아래 DATASOURCE_URL / REDIS_*
#     세팅은 로컬 bootRun 직접 실행 시에만 사용됨).
#   - JWT_SECRET / GOOGLE_* 는 docker 경로에서도 .env 값을 그대로 주입합니다.
# ──────────────────────────────────────────────────────────────────────

# ── Spring profile ───────────────────────────────────────────────────
# local | develop
SPRING_PROFILES_ACTIVE=local

# ── Database (PostgreSQL) ────────────────────────────────────────────
# docker compose 실행 시 불필요 (compose 가 로컬 postgres 컨테이너로 덮어씀).
# bootRun 직접 실행 시에만 채워주세요.
DATASOURCE_URL=postgresql://localhost:5432/teamflow
DB_USER=teamflow
DB_PASSWORD=teamflow

# ── Redis ────────────────────────────────────────────────────────────
# docker compose 실행 시 불필요 (compose 가 로컬 redis 컨테이너로 덮어씀).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ── JWT (필수) ───────────────────────────────────────────────────────
# HS256 용 최소 256bit 시크릿. 팀 공용 로컬 시크릿을 1Password 등에서 공유.
JWT_SECRET=replace-me-with-at-least-256-bit-random-secret-for-hs256

# Refresh Cookie 정책 (환경별 override)
# local:       Lax / Secure=false   (http localhost)
# cross-site:  None / Secure=true
# same-site:   Strict / Secure=true
JWT_COOKIE_SAME_SITE=Lax
JWT_COOKIE_SECURE=false

# ── Google OAuth (로그인 사용 시 필수) ───────────────────────────────
# Google Cloud Console → Credentials 에서 발급.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────
# 콤마 구분. 프론트 dev 서버 주소를 나열합니다.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Docker compose 호스트 포트 (옵션) ────────────────────────────────
# 호스트 5432 / 6379 가 다른 프로세스에 점유돼 있을 때만 지정.
# 컨테이너 내부 포트는 그대로 5432 / 6379, 호스트 매핑만 바뀝니다.
# POSTGRES_HOST_PORT=15432
# REDIS_HOST_PORT=16379

# ── Render 배포 (옵션) ───────────────────────────────────────────────
# 배포 트리거용. 로컬 개발에는 불필요.
RENDER_API_KEY=
RENDER_SERVICE_ID=
RENDER_DEPLOY_HOOK=
